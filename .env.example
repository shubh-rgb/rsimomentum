# Database Configuration
# REQUIRED: Set these credentials to connect to PostgreSQL
POSTGRES_USER=trader
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=marketdb
DB_PORT=5433

# Database Connection URL (format: postgresql://user:password@host:port/database)
# REQUIRED: Update with your actual credentials
DB_URL=postgresql://trader:your_secure_password_here@db:5432/marketdb

# Kite Connect API (Optional - only if using Kite API)
# Get these from your Kite Connect dashboard: https://kite.trade
KITE_API_KEY=your_kite_api_key
KITE_API_SECRET=your_kite_api_secret
KITE_ACCESS_TOKEN=your_kite_access_token

# Application Settings
TOP_N=10
SCAN_INTERVAL_MIN=15

# Streamlit Authentication (Optional - set dashboard credentials)
# STREAMLIT_USERNAME=admin
# STREAMLIT_PASSWORD=your_dashboard_password
